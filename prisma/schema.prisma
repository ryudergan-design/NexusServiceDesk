// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER") // ADMIN, AGENT, USER
  approved      Boolean   @default(false)
  department    String?
  phone         String?
  jobTitle      String?
  
  // Relacionamentos Ticketing
  requestedTickets Ticket[]           @relation("RequestedTickets")
  assignedTickets  Ticket[]           @relation("AssignedTickets")
  transitions      TicketTransition[]
  attachments      Attachment[]
  comments         TicketComment[]

  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  description   String?
  subcategories Subcategory[]
  tickets       Ticket[]
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  tickets    Ticket[]
}

model SLARule {
  id              String   @id @default(cuid())
  priority        String   @unique // LOW, MEDIUM, HIGH, CRITICAL
  responseTime    Int      // em horas
  resolutionTime  Int      // em horas
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   @default("INCIDENT") // INCIDENT, REQUEST, BUG, SUGGESTION, QUESTION
  status      String   @default("NEW")      // NEW, TRIAGE, DEVELOPMENT, TEST, COMPLETED
  priority    String   @default("MEDIUM")   // LOW, MEDIUM, HIGH, CRITICAL
  impact      String   @default("LOW")
  urgency     String   @default("LOW")
  
  // SLA Fields
  responseTimeDue   DateTime?
  resolutionTimeDue DateTime?
  slaPaused         Boolean   @default(false)
  lastSlaPauseAt    DateTime?
  totalPausedTime   Int       @default(0) // em minutos

  // Relacionamentos
  requesterId   String
  requester     User     @relation("RequestedTickets", fields: [requesterId], references: [id])
  
  assigneeId    String?
  assignee      User?    @relation("AssignedTickets", fields: [assigneeId], references: [id])
  
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  attachments   Attachment[]
  transitions   TicketTransition[]
  comments      TicketComment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TicketTransition {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  
  fromStatus String
  toStatus   String
  comment    String?
  
  performedById String
  performedBy   User   @relation(fields: [performedById], references: [id])
  
  createdAt  DateTime @default(now())
}

model TicketComment {
  id         String   @id @default(cuid())
  content    String
  isPrivate  Boolean  @default(false)
  isInternal Boolean  @default(false)
  timeSpent  Int      @default(0)
  
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  
  createdAt  DateTime @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  fileUrl   String
  mimeType  String
  size      Int
  
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  
  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  
  createdAt DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
