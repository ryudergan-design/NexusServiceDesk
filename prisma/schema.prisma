generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String               @id @default(cuid())
  name             String?
  email            String?              @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             String               @default("USER")
  approved         Boolean              @default(false)
  department       String?
  phone            String?
  jobTitle         String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  aiEnabled        Boolean              @default(true)
  isAI             Boolean              @default(false)
  aiApiKey         String?
  aiModel          String?              @default("gemini-1.5-flash")
  aiInstructions   String?
  aiLogs           AILog[]
  accessLogs       AccessLog[]
  accounts         Account[]
  attachments      Attachment[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  surveys          SatisfactionSurvey[]
  sessions         Session[]
  assignedTickets  Ticket[]             @relation("AssignedTickets")
  requestedTickets Ticket[]             @relation("RequestedTickets")
  comments         TicketComment[]
  transitions      TicketTransition[]
}

model KnowledgeArticle {
  id         String   @id @default(cuid())
  title      String
  content    String
  categoryId String
  tags       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AILog {
  id        String   @id @default(cuid())
  agentName String
  ticketId  Int?
  input     String
  output    String
  tokens    Int?
  latency   Int?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  description   String?
  subcategories Subcategory[]
  tickets       Ticket[]
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  tickets    Ticket[]
}

model SLARule {
  id             String   @id @default(cuid())
  priority       String   @unique
  responseTime   Int
  resolutionTime Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Ticket {
  id                Int                 @id @default(autoincrement())
  title             String
  description       String
  type              String              @default("INCIDENT")
  status            String              @default("NEW")
  priority          String              @default("MEDIUM")
  impact            String              @default("LOW")
  urgency           String              @default("LOW")
  responseTimeDue   DateTime?
  resolutionTimeDue DateTime?
  slaPaused         Boolean             @default(false)
  lastSlaPauseAt    DateTime?
  totalPausedTime   Int                 @default(0)
  requesterId       String
  assigneeId        String?
  categoryId        String
  subcategoryId     String?
  budgetAmount      Float?
  budgetDescription String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  plannedDueDate    DateTime?
  plannedStartDate  DateTime?
  attachments       Attachment[]
  survey            SatisfactionSurvey?
  subcategory       Subcategory?        @relation(fields: [subcategoryId], references: [id])
  category          Category            @relation(fields: [categoryId], references: [id])
  assignee          User?               @relation("AssignedTickets", fields: [assigneeId], references: [id])
  requester         User                @relation("RequestedTickets", fields: [requesterId], references: [id])
  comments          TicketComment[]
  transitions       TicketTransition[]
}

model SatisfactionSurvey {
  id        String   @id @default(cuid())
  rating    Int
  feedback  String?
  ticketId  Int      @unique
  userId    String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model TicketTransition {
  id            String   @id @default(cuid())
  ticketId      Int
  fromStatus    String
  toStatus      String
  comment       String?
  performedById String
  createdAt     DateTime @default(now())
  performedBy   User     @relation(fields: [performedById], references: [id])
  ticket        Ticket   @relation(fields: [ticketId], references: [id])
}

model TicketComment {
  id         String   @id @default(cuid())
  content    String
  isPrivate  Boolean  @default(false)
  isInternal Boolean  @default(false)
  timeSpent  Int      @default(0)
  ticketId   Int
  authorId   String
  createdAt  DateTime @default(now())
  author     User     @relation(fields: [authorId], references: [id])
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  fileUrl      String?
  content      String
  mimeType     String
  size         Int
  ticketId     Int
  uploadedById String
  createdAt    DateTime @default(now())
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  ticket       Ticket   @relation(fields: [ticketId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  payload   String?
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AccessLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model KnowledgeArticle_FTS {
  articleId Unsupported("")?
  title     Unsupported("")?
  content   Unsupported("")?
  tags      Unsupported("")?

  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model KnowledgeArticle_FTS_config {
  k Unsupported("")  @id
  v Unsupported("")?

  @@ignore
}

model KnowledgeArticle_FTS_content {
  id Int              @id @default(autoincrement())
  c0 Unsupported("")?
  c1 Unsupported("")?
  c2 Unsupported("")?
  c3 Unsupported("")?
}

model KnowledgeArticle_FTS_data {
  id    Int    @id @default(autoincrement())
  block Bytes?
}

model KnowledgeArticle_FTS_docsize {
  id Int    @id @default(autoincrement())
  sz Bytes?
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model KnowledgeArticle_FTS_idx {
  segid Unsupported("")
  term  Unsupported("")
  pgno  Unsupported("")?

  @@id([segid, term])
  @@ignore
}
